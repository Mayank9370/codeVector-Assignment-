# ─────────────────────────────────────────────────────────────
# Frontend Environment Variable Configurations
# ─────────────────────────────────────────────────────────────
#
# Vite requires environment variables to be prefixed with `VITE_`
# to prevent exposing private server keys to the client.
#
# Copy this file to `.env` in the same directory:
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────

# The base URL pointing to the Express server API endpoints.
# - For local development: http://localhost:3000/api
# - For relative proxy paths: /api
VITE_API_BASE_URL=http://localhost:3000/api
